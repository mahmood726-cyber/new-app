{
  "name": "meta-analysis-platform",
  "version": "2.1.0",
  "description": "Advanced clinical trial meta-analysis and data extraction platform",
  "author": "Mahmood Ahmad",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "d3": "^7.8.5",
    "idb": "^7.1.1",
    "jstat": "^1.9.6"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "eslint": "^8.56.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "meta-analysis",
    "systematic-review",
    "clinical-trials",
    "evidence-synthesis",
    "forest-plot",
    "network-meta-analysis",
    "cochrane"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mahmood789/meta-analysis-platform"
  }
}
